// prisma/schema.prisma
// FacturaGo — Moroccan Invoicing SaaS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────
model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // General Info
  name    String
  address String?
  city    String?
  phone   String?
  email   String?

  // Moroccan Legal (Juridique)
  ice     String? // Identifiant Commun de l'Entreprise (15 digits)
  rc      String? // Registre de Commerce
  taxId   String? // Identifiant Fiscal (IF)
  patente String? // Taxe Professionnelle (Patente)
  cnss    String? // Caisse Nationale de Sécurité Sociale

  // Branding / UI
  logoUrl       String?
  primaryColor  String  @default("#267E54")
  defaultFooter String?

  // Relations
  contacts         Contact[]
  products         Product[]
  documents        Document[]
  payments         Payment[]
  documentSettings DocumentSettings?
}

// ─────────────────────────────────────────────
// CONTACTS (Clients & Fournisseurs)
// ─────────────────────────────────────────────
enum ContactType {
  CLIENT
  FOURNISSEUR
}

enum ContactCategory {
  INDIVIDUAL
  COMPANY
}

model Contact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type     ContactType
  category ContactCategory @default(COMPANY)

  // Identity
  name        String
  companyName String?
  email       String?
  phone       String?
  address     String?
  city        String?
  ice         String? // Client's ICE for invoices

  // Tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relations
  documents Document[]

  @@index([companyId, type])
}

// ─────────────────────────────────────────────
// INVENTORY (Produits & Services)
// ─────────────────────────────────────────────
enum ProductType {
  PRODUCT
  SERVICE
}

model Product {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name           String
  reference      String?
  type           ProductType @default(PRODUCT)
  costPrice      Float       @default(0)
  sellingPriceHT Float       @default(0)
  tvaRate        Float       @default(0.20)
  stockQuantity  Int         @default(0)
  unit           String      @default("unité")

  // Tenant
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Relations
  documentLines  DocumentLine[]
  stockMovements StockMovement[]

  @@index([companyId])
  @@index([reference])
}

// ─────────────────────────────────────────────
// COMMERCIAL DOCUMENTS (The Core Engine)
// ─────────────────────────────────────────────
enum DocumentType {
  DEVIS
  FACTURE
  BON_LIVRAISON
  BON_COMMANDE
  AVOIR
}

enum DocumentStatus {
  DRAFT
  SENT
  PENDING
  PAID
  CONVERTED
  CANCELLED
}

enum PaymentMethod {
  VIREMENT
  CHEQUE
  ESPECES
  CARTE
}

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type    DocumentType
  number  String
  status  DocumentStatus @default(DRAFT)
  date    DateTime       @default(now())
  dueDate DateTime?

  // Totals (computed and cached)
  totalHT   Float @default(0)
  totalTVA  Float @default(0)
  totalTTC  Float @default(0)
  totalPaid Float @default(0)

  // Content
  notes  String?
  footer String?

  // Conversion Chain
  convertedFromId String?
  convertedFrom   Document?  @relation("DocumentConversion", fields: [convertedFromId], references: [id])
  convertedTo     Document[] @relation("DocumentConversion")

  // Relations
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  lines          DocumentLine[]
  stockMovements StockMovement[]
  payments       Payment[]

  @@unique([companyId, number])
  @@index([companyId, type])
  @@index([companyId, status])
  @@index([contactId])
}

model DocumentLine {
  id    String @id @default(cuid())
  order Int    @default(0)

  description String
  quantity    Int    @default(1)
  unitPriceHT Float  @default(0)
  tvaRate     Float  @default(0.20)

  // Computed
  totalHT  Float @default(0)
  totalTVA Float @default(0)
  totalTTC Float @default(0)

  // Relations
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  @@index([documentId])
}

// ─────────────────────────────────────────────
// STOCK LEDGER
// ─────────────────────────────────────────────
enum MovementType {
  IN
  OUT
}

model StockMovement {
  id   String   @id @default(cuid())
  date DateTime @default(now())

  type     MovementType
  quantity Int
  reason   String?

  // Relations
  productId String
  product   Product @relation(fields: [productId], references: [id])

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id])

  @@index([productId])
  @@index([documentId])
}

// ─────────────────────────────────────────────
// DOCUMENT DISPLAY SETTINGS (per tenant)
// ─────────────────────────────────────────────
model DocumentSettings {
  id String @id @default(cuid())

  // Column Toggles
  showReference Boolean @default(true)
  showTvaColumn Boolean @default(true)
  showDiscount  Boolean @default(false)
  showUnitPrice Boolean @default(true)

  // PDF Branding
  primaryColor String @default("#267E54")
  footerText   String @default("Merci pour votre confiance.")
  paperSize    String @default("A4")

  // Tenant
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PAYMENTS LEDGER
// ─────────────────────────────────────────────
model Payment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  
  date      DateTime @default(now())
  amount    Float
  method    PaymentMethod
  reference String?
  notes     String?

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([companyId])
}
